# === API kulcsok (KÖTELEZŐ) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Adatbázis ===
# A docker-compose alapértelmezéseihez illeszkedő kapcsolat:
DATABASE_URL=postgresql://szabalymester:szabalymester@localhost:5432/szabalymester

# A docker-compose ezeket olvassa (opcionális felülírás):
POSTGRES_USER=szabalymester
POSTGRES_PASSWORD=szabalymester
POSTGRES_DB=szabalymester
POSTGRES_PORT=5432

# === Modellek (opcionális — a spine web-ellenőrzött alapértelmezései, .env-ből felülírható) ===
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
HYDE_MODEL=gpt-5.4-nano
RERANK_MODEL=claude-haiku-4-5
ANSWER_MODEL=claude-sonnet-5

# === Pipeline paraméterek (opcionális) ===
WIDE_NET=20
KEEP_TOP=5

# === INGYENES LOKÁLIS MÓD (minden Ollamán, előfizetés nélkül) ===
# Az Ollama natívan beszéli az OpenAI-formátumot, ezért MINDEN modell-szerep mehet a helyi
# Ollamára az OpenAI-kompatibilis végponton át — LiteLLM NÉLKÜL. A rerank/válasz providerét a
# RERANK_PROVIDER/ANSWER_PROVIDER=openai kapcsolja. Részletes útmutató: docs/local-mode.md.
#
# Lépések: 1) Ollama fut (ollama serve); 2) modellek:
#   ollama pull qwen2.5:3b ; ollama pull nomic-embed-text
# majd kommenteld BE az alábbiakat (a titkok lokálisan dummyk):
#
# OPENAI_API_KEY=sk-local-anything
# ANTHROPIC_API_KEY=sk-local-anything
# OPENAI_BASE_URL=http://localhost:11434/v1     # a helyi Ollama OpenAI-kompatibilis végpontja
# HYDE_MODEL=qwen2.5:3b
# RERANK_MODEL=qwen2.5:3b
# RERANK_PROVIDER=openai                         # a rerank is az Ollamára (nem Anthropic)
# ANSWER_MODEL=qwen2.5:3b
# ANSWER_PROVIDER=openai                         # a válasz is az Ollamára (nem Anthropic)
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768                       # a modell dimenziója (nomic=768, mxbai=1024)
# SCHEMA_VECTOR_DIM=768
# (majd a db/schema.sql-ben a vector(1536) -> vector(768), és pnpm ingest --rebuild)
#
# Alternatíva (ha ragaszkodsz az Anthropic-adapterhez): LiteLLM proxy Anthropic->Ollama
# átjáróként (ANTHROPIC_BASE_URL=http://localhost:4000/v1, RERANK/ANSWER_PROVIDER=anthropic).
# Figyelem: a legújabb litellm Windows-on Rust/MSVC build-toolt igényel — ld. docs/local-mode.md.
