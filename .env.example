# === API kulcsok (KÖTELEZŐ) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Adatbázis ===
# A docker-compose alapértelmezéseihez illeszkedő kapcsolat:
DATABASE_URL=postgresql://szabalymester:szabalymester@localhost:5432/szabalymester

# A docker-compose ezeket olvassa (opcionális felülírás):
POSTGRES_USER=szabalymester
POSTGRES_PASSWORD=szabalymester
POSTGRES_DB=szabalymester
POSTGRES_PORT=5432

# === Modellek (opcionális — a spine web-ellenőrzött alapértelmezései, .env-ből felülírható) ===
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
HYDE_MODEL=gpt-5.4-nano
RERANK_MODEL=claude-haiku-4-5
ANSWER_MODEL=claude-sonnet-5

# === Pipeline paraméterek (opcionális) ===
WIDE_NET=20
KEEP_TOP=5

# === INGYENES LOKÁLIS MÓD (Ollama + LiteLLM proxy, előfizetés nélkül) ===
# A kód base-URL-je env-ből felülírható: az OpenAI-formátum (embedding + HyDE) a helyi
# Ollama OpenAI-kompatibilis végpontjára, az Anthropic-formátum (rerank + válasz) a LiteLLM
# proxyra megy. Részletes útmutató: docs/local-mode.md.
#
# Lépések: 1) Ollama fut (ollama serve) + modellek (ld. lent); 2) LiteLLM proxy:
#   $env:OLLAMA_API_BASE="http://localhost:11434"
#   uvx --from "litellm[proxy]" litellm --config litellm.config.yaml --port 4000
# majd kommenteld BE az alábbiakat (a titkok lokálisan dummyk lehetnek):
#
# OPENAI_API_KEY=sk-local-anything
# ANTHROPIC_API_KEY=sk-local-anything
# OPENAI_BASE_URL=http://localhost:11434/v1     # Ollama OpenAI-kompatibilis (embedding + HyDE)
# ANTHROPIC_BASE_URL=http://localhost:4000/v1   # LiteLLM proxy (rerank + válasz); a /v1 KELL
# HYDE_MODEL=qwen2.5:3b                          # helyi chat-modell (Ollama)
# RERANK_MODEL=szabalymester-local              # a litellm.config.yaml aliasa
# ANSWER_MODEL=szabalymester-local              # a litellm.config.yaml aliasa
# Embedding lokálisan (a dimenzió a modelltől függ — a sémát is állítsd be!):
#   ollama pull mxbai-embed-large   (1024 dim)   VAGY   ollama pull nomic-embed-text (768 dim)
# EMBEDDING_MODEL=mxbai-embed-large
# EMBEDDING_DIMENSIONS=1024
# SCHEMA_VECTOR_DIM=1024
# (majd a db/schema.sql-ben a vector(1536) -> vector(1024), és pnpm ingest --rebuild)
