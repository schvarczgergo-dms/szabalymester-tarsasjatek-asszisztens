{
  "name": "szabalymester",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RAG-alapú társasjáték-szabály asszisztens (magyar, forrásmegjelöléssel)",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "ingest": "tsx src/ingest/ingest.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:schema": "docker compose exec -T db psql -v ON_ERROR_STOP=1 -U szabalymester -d szabalymester -f /docker-entrypoint-initdb.d/schema.sql"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/openai": "^4.0.16",
    "ai": "^7.0.31",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
